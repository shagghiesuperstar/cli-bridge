# cli-bridge settings.
#
# Easiest way to create your .env:  python3 bridge.py setup
# Or copy this file to ".env" and fill in the values by hand.
#
# Every setting below is an environment variable. The bridge reads them from
# this .env file on startup. Lines starting with # are comments and are ignored.

# REQUIRED. The command that starts your program: a name on your PATH, or a
# full path. Find it with:  which <name>
CLI_BRIDGE_BIN=

# REQUIRED. Model name(s) your program accepts, comma-separated. The first one
# is the default. These are the names your client (for example Hermes) will use.
CLI_BRIDGE_MODELS=

# Where the bridge listens.
#   PORT  18800 is a safe default.
#   HOST  127.0.0.1 means this machine only, which is what you want. Read the
#         security note in docs/01-install.md before changing it to anything else.
CLI_BRIDGE_PORT=18800
CLI_BRIDGE_HOST=127.0.0.1

# ----- Optional. Sensible defaults are shown; leave a line commented to use it. -----

# Model to use when a request names none. Defaults to the first CLI_BRIDGE_MODELS.
# CLI_BRIDGE_DEFAULT_MODEL=

# Seconds before a single request is abandoned. Raise it for long tasks.
# CLI_BRIDGE_TIMEOUT=600

# Largest prompt the bridge will pass to your program, in characters.
# CLI_BRIDGE_MAX_PROMPT_CHARS=60000

# Most CLI runs the bridge will start at the same time. Further requests wait
# their turn. This caps load and protects the account behind your program.
# CLI_BRIDGE_MAX_CONCURRENCY=4

# Largest request body the bridge will accept, in bytes. Default is 64 MiB.
# Mainly a guard against oversized uploads (for example very large images).
# CLI_BRIDGE_MAX_BODY_BYTES=67108864

# Logging detail. Use DEBUG for more output when troubleshooting.
# CLI_BRIDGE_LOG_LEVEL=INFO
