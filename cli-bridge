#!/bin/sh
# cli-bridge launcher. Works straight from a fresh clone:  ./cli-bridge setup
# `setup` can also put a `cli-bridge` command on your PATH so you can drop the
# leading ./ and run it from anywhere.
DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
if [ -x "$DIR/.venv/bin/python3" ]; then
    exec "$DIR/.venv/bin/python3" "$DIR/bridge.py" "$@"
fi
exec python3 "$DIR/bridge.py" "$@"
